SHOPIFY_STORE_URL=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2026-01

# Cross-call metadata cache TTL (seconds) — A8 / Story 10.32.
# How long the publication-channels roster is cached across MCP tool calls before
# a re-fetch (default 600 = 10m). Channel-affecting writes (publish/unpublish)
# invalidate the entry immediately, independent of this TTL.
CACHE_TTL_CHANNELS_S=600

# Webhook receiver (Railway deployment — filled in after PR Workstream 2)
WEBHOOK_RECEIVER_URL=https://your-app.railway.app/webhooks

# Comma-separated hostnames allowed as webhook endpoints (M3 security fix).
# If set, register_webhook rejects any endpoint_url whose hostname is not listed.
# If unset, a ⚠ EXTERNAL DOMAIN warning is shown in the preview instead.
WEBHOOK_ALLOWLIST_HOSTS=your-app.railway.app

# Shopify webhook HMAC signing secret (Custom App → API credentials → Client secret)
SHOPIFY_WEBHOOK_SECRET=your_client_secret_here

# GA4 Measurement Protocol (used by remote receiver; stored here for reference)
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
GA4_API_SECRET=your_ga4_api_secret_here
